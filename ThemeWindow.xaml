<Window x:Class="Boundless.ThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="主题设置 - 澪一 无界" Height="500" Width="500" 
        Background="#1E1E1E" WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="选择你喜欢的主题样式" Foreground="White" FontSize="16" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <ListBox Name="ThemeListBox" Grid.Row="1" Background="#2D2D2D" BorderBrush="#555" 
                 SelectionChanged="ThemeListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Description}" Foreground="#AAA" FontSize="11" Margin="0,2,0,0"/>
                        <TextBlock Foreground="#888" FontSize="10" Margin="0,2,0,0">
                            <Run Text="作者: "/>
                            <Run Text="{Binding Author}"/>
                            <Run Text=" | 版本: "/>
                            <Run Text="{Binding Version}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Name="BtnApply" Content="应用主题" Width="100" Height="30" Margin="5" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Apply_Click"/>
            <Button Name="BtnRefresh" Content="刷新列表" Width="100" Height="30" Margin="5" Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Refresh_Click"/>
            <Button Name="BtnOpenFolder" Content="打开主题目录" Width="100" Height="30" Margin="5" Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand" Click="OpenFolder_Click"/>
        </StackPanel>
    </Grid>
</Window>

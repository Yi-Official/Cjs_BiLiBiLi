<Window x:Class="Boundless.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键设置 - 澪一 无界" Height="450" Width="460" 
        Background="#1E1E1E" WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="点击输入框按下新快捷键，按 Esc 取消绑定" Foreground="#AAA" FontSize="12" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Name="HotkeysPanel">
            </StackPanel>

        <Button Grid.Row="2" Content="保存并应用" Height="35" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Save_Click"/>
    </Grid>
</Window>
<Window x:Class="Boundless.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键设置 - 澪一 无界" Height="680" Width="460"
        Background="#1E1E1E" WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 快捷键说明 -->
        <TextBlock Text="点击输入框按下新快捷键，按 Esc 取消绑定" Foreground="#AAA" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <!-- 快捷键列表 -->
        <StackPanel Grid.Row="1" Name="HotkeysPanel"/>

        <!-- 默认打开地址 -->
        <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="6" Padding="12" Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="默认打开地址" Foreground="#CCC" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <DockPanel Grid.Row="1">
                    <Button Name="BtnSetDefault" Content="保存地址" Width="70" Height="26" DockPanel.Dock="Right" Margin="5,0,0,0"
                            Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSetDefault_Click"/>
                    <TextBox Name="TxtDefaultAddress" Height="26" VerticalContentAlignment="Center" FontSize="12"
                             Background="#555" Foreground="White" BorderThickness="1" BorderBrush="#888" Padding="8,0"
                             Text="https://www.bilibili.com"/>
                </DockPanel>
            </Grid>
        </Border>

        <!-- 自定义图标 -->
        <Border Grid.Row="3" Background="#2D2D2D" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="自定义托盘图标" Foreground="#CCC" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <DockPanel Grid.Row="1">
                    <Button Name="BtnBrowseIcon" Content="浏览..." Width="70" Height="26" DockPanel.Dock="Right" Margin="5,0,0,0"
                            Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseIcon_Click"/>
                    <Button Name="BtnClearIcon" Content="清除" Width="50" Height="26" DockPanel.Dock="Right" Margin="0,0,5,0"
                            Background="#555" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClearIcon_Click"/>
                    <TextBox Name="TxtIconPath" Height="26" VerticalContentAlignment="Center" FontSize="11"
                             Background="#555" Foreground="White" BorderThickness="1" BorderBrush="#888" Padding="8,0"
                             IsReadOnly="True"/>
                </DockPanel>
            </Grid>
        </Border>

        <Button Grid.Row="5" Content="保存并应用" Height="35" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Save_Click"/>
    </Grid>
</Window>
